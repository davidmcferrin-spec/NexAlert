# NexAlert - Environment Configuration
# Copy to .env and fill in real values. Never commit .env to git.

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
APP_ENV=development
# development | production
APP_URL=https://nexalert.area51consulting.com
APP_NAME=NexAlert
APP_TIMEZONE=America/Chicago

# Secret used for JWT signing (min 64 chars, generate with: openssl rand -hex 64)
APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# -----------------------------------------------------------------------
# Database (get host/db name from Dreamhost panel → MySQL)
# -----------------------------------------------------------------------
DB_HOST=mysql.area51consulting.com
DB_PORT=3306
DB_NAME=nexalert
DB_USER=nexalert_user
DB_PASS=CHANGE_ME
DB_CHARSET=utf8mb4

# -----------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB_QUEUE=0
REDIS_DB_PUBSUB=1

# -----------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------
JWT_ALGO=HS256
JWT_TTL_MINUTES=480
# 8 hours; refresh token TTL
JWT_REFRESH_TTL_DAYS=30

# -----------------------------------------------------------------------
# Twilio (Phase 2 - leave blank for Phase 1 stub)
# -----------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Inbound webhook URL Twilio will POST to
TWILIO_WEBHOOK_URL=https://nexalert.area51consulting.com/api/v1/webhooks/twilio/sms

# -----------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.dreamhost.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=nexalert@area51consulting.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=nexalert@area51consulting.com
MAIL_FROM_NAME=NexAlert

# -----------------------------------------------------------------------
# Web Push / VAPID (Phase 3 - generate with: php artisan vapid or manual)
# Generate: openssl ecparam -name prime256v1 -genkey -noout -out vapid_private.pem
# -----------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nexalert@area51consulting.com

# -----------------------------------------------------------------------
# Azure Entra ID (Phase 5)
# -----------------------------------------------------------------------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=https://nexalert.area51consulting.com/auth/entra/callback

# -----------------------------------------------------------------------
# LDAP (Phase 5)
# -----------------------------------------------------------------------
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASS=
LDAP_USE_TLS=true

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
LOG_LEVEL=debug
# debug | info | warning | error
LOG_PATH=/home/dh_w9tij7/logs/nexalert/app.log

# -----------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------
# Comma-separated IPs allowed to access /api/v1/admin/* (empty = any)
ADMIN_IP_ALLOWLIST=
# Bcrypt cost factor
BCRYPT_COST=12
