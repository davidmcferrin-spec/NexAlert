# NexAlert - Root .htaccess
Options -Indexes
Options -MultiViews

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block dotfiles except .well-known
RewriteRule ^\.(?!well-known) - [F,L]

# Block direct access to source directories (but NOT api/ - that's routed below)
RewriteRule ^(workers/|config/|db/|tests/|docs/) - [F,L]

# Route /api/* to index.php
RewriteRule ^api/(.*)$ index.php [L,QSA]

# Route everything else to app.php (skip real files/dirs)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ app.php [L,QSA]

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>